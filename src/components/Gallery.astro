---
import { Image, getImage } from 'astro:assets';

import Luka from '../images/paintings/Luka.jpeg';
import ManWithAntlers from '../images/paintings/Man_with_Antlers.jpeg';
import GirlWithSkateboard from '../images/paintings/Girl_with_Skateboard.jpeg';
import RedUmbrella from '../images/paintings/Red_Umbrella.jpeg';
import ManWithHarmonica from '../images/paintings/Man_with_Harmonica.jpg';
import ManWithSaxophone from '../images/paintings/Man_with_Saxophone.jpeg';
import ShrikeWithFruits from '../images/paintings/Shrike_with_Fruits.jpeg';
import ThreeHeads from '../images/paintings/Three_Heads.jpg';
import BITE from '../images/paintings/BITE.jpeg';
import WomaninRed from '../images/paintings/Woman_in_Red.jpeg';

const paintings = await Promise.all([
  { img: Luka,              alt: 'A portrait of a black cat wearing a Victorian-era coat', title: 'Luka',               medium: 'oil on canvas, 50x60cm' },
  { img: ManWithAntlers,   alt: 'Man with Antlers',                                       title: 'Man with Antlers',   medium: 'acrylic on canvas, 65x85cm' },
  { img: ShrikeWithFruits, alt: 'A painting of a shrike in a teacup',                    title: 'Shrike with Fruits', medium: 'oil on canvas, 50x60cm' },
  { img: GirlWithSkateboard, alt: 'Girl with skateboard',                                 title: 'Girl with Skateboard', medium: 'oil on canvas, 60x70cm' },
  { img: WomaninRed,       alt: 'Woman wearing red',                                      title: 'Woman in Red',       medium: 'oil on canvas, 40x50cm' },
  { img: RedUmbrella,      alt: 'A painting of a woman with a red umbrella',              title: 'Red Umbrella',       medium: 'oil on canvas, 40x30cm' },
  { img: BITE,             alt: 'A painting of dog mouths',                               title: 'BITE',               medium: 'oil on canvas, 40x50cm' },
  { img: ThreeHeads,       alt: 'A painting of three heads',                              title: 'Three Heads',        medium: 'acrylic on canvas, 50x75cm' },
  { img: ManWithHarmonica, alt: 'A man sitting down playing a harmonica',                 title: 'Man with Harmonica', medium: 'acrylic on canvas, 45x60cm' },
  { img: ManWithSaxophone, alt: 'A portrait of a man playing a saxophone',                title: 'Man with Saxophone', medium: 'acrylic on canvas, 45x60cm' },
].map(async p => ({
  ...p,
  full: (await getImage({ src: p.img, width: 1200, format: 'webp', quality: 85 })).src,
})));
---

<div class="container mx-auto px-4 py-6 fadeInUp" id="gallery">
  {paintings.map((p, i) => (
    <figure class="image-figure" data-index={i} data-full={p.full}>
      <Image
        src={p.img}
        alt={p.alt}
        loading={i < 2 ? 'eager' : 'lazy'}
        fetchpriority={i === 0 ? 'high' : 'auto'}
        sizes="(max-width: 600px) 100vw, (max-width: 960px) 50vw, 33vw"
      />
      <figcaption>
        <p class="text-base">{p.title}</p>
        <p class="text-xs">{p.medium}</p>
      </figcaption>
    </figure>
  ))}
</div>

<style>
  #gallery {
    column-count: 1;
    column-gap: 16px;
  }
  @media (min-width: 640px)  { #gallery { column-count: 2; } }
  @media (min-width: 1024px) { #gallery { column-count: 3; } }

  .image-figure {
    break-inside: avoid;
    margin-bottom: 16px;
  }

  #lb-img {
    opacity: 0;
  }
  #lb-img.lb-loaded {
    opacity: 1;
    transition: opacity 0.3s ease;
  }
</style>

<!-- Lightbox -->
<div
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
  class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center flex-col"
>
  <button id="lb-close" aria-label="Close"
    class="absolute top-4 right-6 text-white text-4xl leading-none hover:opacity-70 cursor-pointer">
    &times;
  </button>
  <button id="lb-prev" aria-label="Previous image"
    class="absolute left-4 top-1/2 -translate-y-1/2 text-white text-5xl leading-none hover:opacity-70 cursor-pointer select-none">
    &#8249;
  </button>
  <button id="lb-next" aria-label="Next image"
    class="absolute right-4 top-1/2 -translate-y-1/2 text-white text-5xl leading-none hover:opacity-70 cursor-pointer select-none">
    &#8250;
  </button>
  <div id="lb-spinner" class="hidden absolute inset-0 items-center justify-center pointer-events-none">
    <div class="w-8 h-8 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
  </div>
  <img id="lb-img" src="" alt="" class="max-h-[82vh] max-w-[88vw] object-contain select-none" />
  <div class="text-center mt-4 text-white pointer-events-none">
    <p id="lb-title" class="text-xl"></p>
    <p id="lb-medium" class="text-sm text-gray-300"></p>
  </div>
  <p id="lb-counter" class="text-gray-500 text-xs mt-2 pointer-events-none"></p>
</div>

<script>
  const figures = Array.from(document.querySelectorAll<HTMLElement>('#gallery .image-figure'));

  const paintings = figures.map(fig => {
    const img = fig.querySelector<HTMLImageElement>('img')!;
    const ps  = fig.querySelectorAll('figcaption p');
    return { src: fig.dataset.full ?? img.src, alt: img.alt, title: ps[0]?.textContent ?? '', medium: ps[1]?.textContent ?? '' };
  });

  const lb        = document.getElementById('lightbox')!;
  const lbImg     = document.getElementById('lb-img') as HTMLImageElement;
  const lbSpinner = document.getElementById('lb-spinner')!;
  const lbTitle   = document.getElementById('lb-title')!;
  const lbMedium  = document.getElementById('lb-medium')!;
  const lbCounter = document.getElementById('lb-counter')!;
  let current = 0;

  // preload all images in the background
  paintings.forEach(p => { const img = new Image(); img.src = p.src; });

  lbImg.addEventListener('load', () => {
    lbSpinner.classList.remove('flex');
    lbSpinner.classList.add('hidden');
    lbImg.classList.add('lb-loaded');
  });

  function openLightbox(i: number) {
    current = i;
    const p = paintings[i];
    lbImg.classList.remove('lb-loaded');
    lbImg.removeAttribute('src');
    lbSpinner.classList.remove('hidden');
    lbSpinner.classList.add('flex');
    lbImg.alt = p.alt;
    lbImg.src = p.src;
    lbTitle.textContent = p.title;
    lbMedium.textContent = p.medium;
    lbCounter.textContent = `${i + 1} / ${paintings.length}`;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function prev() { openLightbox((current - 1 + paintings.length) % paintings.length); }
  function next() { openLightbox((current + 1) % paintings.length); }

  document.getElementById('gallery')!.addEventListener('click', (e) => {
    const fig = (e.target as Element).closest('.image-figure');
    if (!fig) return;
    const i = figures.indexOf(fig as HTMLElement);
    if (i !== -1) openLightbox(i);
  });

  document.getElementById('lb-close')!.addEventListener('click', closeLightbox);
  document.getElementById('lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); prev(); });
  document.getElementById('lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); next(); });
  lb.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });

  let touchStartX = 0;
  lb.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', (e) => {
    const delta = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(delta) > 50) delta < 0 ? next() : prev();
  });

  document.addEventListener('keydown', (e) => {
    if (lb.classList.contains('hidden')) return;
    if (e.key === 'Escape')      closeLightbox();
    if (e.key === 'ArrowLeft')   prev();
    if (e.key === 'ArrowRight')  next();
  });
</script>
