---
const path = Astro.url.pathname;
const isPortfolio = path === '/' || path === '';
const isAbout = path.startsWith('/about');
---

<nav class="nav flex flex-wrap items-center justify-between px-4 pt-10 p-3 fadeInDown navbar">
  <div class="container mx-auto flex flex-wrap items-center md:flex-no-wrap">

    <div class="flex flex-no-shrink items-center mr-6 py-3 text-grey-darkest">
      <div class="mr-4 md:mr-8">
        <a href="/" class="text-2xl font-semibold">Narmeen Zain</a>
      </div>
    </div>

    <input class="menu-btn hidden" type="checkbox" id="menu-btn" />
    <label class="menu-icon block cursor-pointer md:hidden px-2 py-4 relative select-none" for="menu-btn">
      <span class="navicon bg-grey-darkest flex items-center relative"></span>
    </label>

    <ul class="navbar-nav menu border-b md:border-none flex justify-end list-none m-0 w-full md:w-auto mt-5 md:flex-row md:items-center md:ml-auto md:mt-0 md:pt-0 md:border-0">
      <li class="border-t md:border-none">
        <a href="/" class={`link block md:inline-block px-4 py-3 text-2xl tap-highlight-transparent${isPortfolio ? ' activelink' : ''}`}>
          PORTFOLIO
        </a>
      </li>
      <li class="border-t md:border-none">
        <a href="/about" class={`link block md:inline-block px-4 py-3 text-2xl tap-highlight-transparent${isAbout ? ' activelink' : ''}`}>
          ABOUT
        </a>
      </li>
    </ul>

  </div>
</nav>
