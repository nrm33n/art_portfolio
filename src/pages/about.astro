---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import mee from '../images/mee2.jpeg';
import sculpture from '../images/sculpture.jpg';
---

<Layout title="About — Narmeen Zain" description="Narmeen Zain is an artist and computer scientist.">
  <div class="w-full md:w-[80%] mx-auto p-3 md:p-1 fadeInUp">

    <!-- portrait + bio -->
    <div class="flex flex-row items-center justify-around w-full pt-12">
      <p class="md:pl-[10%] text-gray-500">Mostly an oil painter.</p>
      <Image src={mee} alt="Artist portrait" loading="eager" fetchpriority="high" id="portrait" class="rounded-full h-36 w-36 hover:animate-pulse opacity-0 transition-opacity duration-700" />
    </div>


    <div class="flex justify-center mt-8">
    <div class="w-full md:w-[60%] mx-auto">

    <div class="w-fit mx-auto">

    <!-- exhibitions -->
    <p class="text-lg text-gray-800 font-bold p-1 pb-4">SELECTED EXHIBITIONS</p>
    <p class="p-1">2025 <b><i>Freedom</i></b>, National Academy of Art, India</p>
    <p class="p-1">2025 <b><i>внутри</i></b>, G Gallery, Samara, Russia</p>
    <p class="p-1">2024 <b><i>Emozion</i></b>, Gadarte Associazione Culturale, Florence, Italy</p>
    <p class="p-1">2024 — Present, Telavi History Museum, Telavi, Georgia</p>
    <p class="p-1">2023 <b><i>ISOAG Annual Art Exhibition</i></b>, Dubai, UAE</p>
    <p class="p-1">2023 <b><i>One World One Earth</i></b>, Taj Mahal Palace Hotel, Mumbai, India</p>
    <p class="p-1">2023 <b><i>Annual Exhibition</i></b>, Rukseen Art Gallery, Dubai, United Arab Emirates</p>
    <p class="p-1">2023 <b><i>Vasudhaiv Kutumbakam</i></b>, Embassy of India, Abu Dhabi, United Arab Emirates</p>
    <p class="p-1">2023 <b><i>A Journey Through Creativity</i></b>, Hotel H, Dubai, United Arab Emirates</p>
    <p class="p-1">2012 – 2014, ArtChowk — the Gallery, Karachi, Pakistan</p>
    <p class="p-1">2014 <b><i>Students' Exhibition</i></b>, Gallery 76, Dubai, United Arab Emirates</p>

    <!-- press -->
    <div class="my-12 h-px border-t-0 bg-gradient-to-b from-gray-400 via-gray-700 to-transparent opacity-50"></div>
    <p class="text-lg text-gray-800 font-bold p-1 pb-4">SELECTED PRESS & PUBLICATIONS</p>
    <p class="p-1">2026 <b>Editor's Choice 2026 Calendar</b> published by Tovu Ovimaan </p>
    <p class="p-1">2024 <b>Canvas of Artist Memories</b> coffee table book published by Namaste Magazine</p>

    <p class="p-1">2023 <i>"<a class="underline decoration-2 decoration-orange-600 hover:no-underline hover:text-orange-900" 
    href="https://www.gulftoday.ae/culture/2023/09/21/the-art-of-dreams-computer-scientist-narmeen-zain-teams-with-dreams-for-art"><b>The Art of Dreams</b>: Computer scientist Narmeen Zain teams with dreams for art"</a></i>, Gulf Today</p>

    <!-- distinctions -->
    <div class="my-12 h-px border-t-0 bg-gradient-to-b from-gray-400 via-gray-700 to-transparent opacity-50"></div>
    <p class="text-lg text-gray-800 font-bold p-1 pb-4">DISTINCTIONS</p>
    <p class="p-1">2013 <b>Juror's Choice</b>, Gallery 72, Dubai, United Arab Emirates</p>
    <p class="p-1 pb-16">2011 <b>First Place</b>, Gallery 72, Dubai, United Arab Emirates</p>

    </div>

    </div>
    </div>

    <!-- sculpture -->
    <Image src={sculpture} alt="Sculpture of a human head" class="rounded w-full fadeInUp" loading="lazy" />


  </div>
<script>
  const portrait = document.getElementById('portrait') as HTMLImageElement;
  function show() { portrait.classList.remove('opacity-0'); }
  if (portrait.complete) show();
  else portrait.addEventListener('load', show);
</script>
</Layout>
